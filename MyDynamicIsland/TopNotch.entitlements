<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Sandbox disabled for direct build — required for private framework access -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <!-- Networking for weather API and YouTube -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Calendar access for the Calendar widget -->
    <key>com.apple.security.personal-information.calendars</key>
    <true/>
    <!-- Location for accurate weather -->
    <key>com.apple.security.personal-information.location</key>
    <true/>
    <!-- Read app paths for the App Launcher widget -->
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>
    <!-- Allow AppleEvents to launch apps from App Launcher -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
