{
  "name": "appsetupkit",
  "version": "3.0.0",
  "description": "App Setup Kit - Multi-platform app launch automation (Swift + Expo/React Native)",
  "main": "setup.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node setup.js",
    "setup:swift": "bash swift-setup.sh",
    "setup:expo": "node setup.js --expo",
    "setup:metadata": "bash scripts/fastlane-metadata-setup.sh",
    "setup:auth": "bash scripts/supabase-auth-setup.sh",
    "check": "bash check-prerequisites.sh"
  },
  "dependencies": {}
}
